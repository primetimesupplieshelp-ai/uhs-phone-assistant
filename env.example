# ─────────────────────────────────────────────
# UHS Phone Assistant — Environment Variables
# ─────────────────────────────────────────────
# Copy this file's variable names into Railway:
# Railway Dashboard → Your Project → Variables → Add variable
#
# DO NOT paste this file with real values into GitHub.
# ─────────────────────────────────────────────

# Twilio Account SID — found at twilio.com/console
TWILIO_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Twilio Auth Token — found at twilio.com/console
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Your Twilio phone number (with country code)
TWILIO_FROM=+1xxxxxxxxxx

# Mohammad's number to receive repair alert SMS (with country code)
# If left unset, alerts will go to TWILIO_FROM
TEAM_NOTIFY_TO=+1xxxxxxxxxx

# Your Netlify quote form URL
QUOTE_LINK=https://your-site.netlify.app
